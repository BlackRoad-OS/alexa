# BlackRoad OS — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── Authentik ─────────────────────────────────────────────────────────────
PG_PASS=
AUTHENTIK_SECRET_KEY=

# ── LiteLLM ───────────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=
LITELLM_DB_PASS=
LITELLM_DATABASE_URL=postgresql://litellm:<LITELLM_DB_PASS>@litellm-db:5432/litellm

# ── AI Vendor keys (stored only on your gateway host) ─────────────────────
BLACKBOXAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
